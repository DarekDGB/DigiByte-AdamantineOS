{
  "$id": "adamantine:contracts:upgrade_proposal_v3.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive Core Upgrade Proposal v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "v",
    "proposal_id",
    "domain",
    "action",
    "target",
    "created_utc",
    "summary",
    "changes",
    "proposal_hash"
  ],
  "properties": {
    "v": { "type": "string", "const": "upgrade_proposal_v3" },
    "proposal_id": { "type": "string", "minLength": 1 },
    "domain": {
      "type": "string",
      "enum": ["SECURITY_THRESHOLDS", "DETECTION_RULES", "ENFORCEMENT", "GUARDRAILS"]
    },
    "action": {
      "type": "string",
      "enum": [
        "INCREASE_THRESHOLD",
        "ADD_RULE",
        "TIGHTEN_EVIDENCE",
        "STRENGTHEN_ENFORCEMENT",
        "ADD_GUARDRAIL"
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component", "version"],
      "properties": {
        "component": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "created_utc": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["change_id", "type", "detail"],
        "properties": {
          "change_id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["add", "modify", "deprecate", "remove"] },
          "detail": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence": { "type": "object" },
    "guardrails": {
      "type": ["array", "null"],
      "items": { "type": "string", "minLength": 1 }
    },
    "guardrails_ref": { "type": ["string", "null"] },
    "proposal_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
